{
    "manifest_version": 3,
    "name": "Web3 Scam Detector",
    "version": "1.0",
    "description": "Detects and alerts users about possible Web3-related scams on websites.",
    "permissions": ["scripting", "tabs", "activeTab", "storage"],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "128": "icons/icon128.png"
      }
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"]
      }
    ],
    "icons": {
      "128": "icons/icon128.png"
    }
  }
  